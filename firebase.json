{
  "hosting": {
    "source": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "frameworksBackend": {
      "region": "asia-east1"
    },
    "headers": [
      {
        "source": "/_next/image**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=60, s-maxage=31536000, stale-while-revalidate=86400"
          }
        ]
      }
    ]
  }
}
